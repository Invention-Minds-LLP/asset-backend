  id Int @id @default(autoincrement())

  // What the notification is about (optional links)
  assetId Int?
  asset   Asset? @relation(fields: [assetId], references: [id])

  ticketId Int?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  gatePassId Int?
