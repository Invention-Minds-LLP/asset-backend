  frequencyUnit  String // DAYS | MONTHS | YEARS

  startDate DateTime?  // the date from which the schedule begins
  nextDueAt DateTime
  isActive  Boolean  @default(true)

  createdBy   String?
  createdById Int?
  reason      String?
  description String?  @db.Text

