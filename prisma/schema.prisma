  parentStoreId Int?
  parentStore   Store?  @relation("StoreHierarchy", fields: [parentStoreId], references: [id])
  childStores   Store[] @relation("StoreHierarchy")

  branchId     Int?
  departmentId Int?
  managerId    Int?
  address      String? @db.Text
  isActive     Boolean @default(true)

  createdById Int?
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  locations          StoreLocation[]
  stockPositions     StoreStockPosition[]
  transfersFrom      StoreTransfer[]      @relation("TransferFromStore")
  transfersTo        StoreTransfer[]      @relation("TransferToStore")
  materialIssues     MaterialIssue[]
  goodsReceiptLines  GoodsReceiptLine[]   @relation("GRALineStore")
  purchaseOrderLines PurchaseOrderLine[]  @relation("POLineStore")

  @@map("store")
}

model StoreLocation {
  id       Int     @id @default(autoincrement())
  storeId  Int
  store    Store   @relation(fields: [storeId], references: [id])
  rack     String?
  shelf    String?
  bin      String?
  label    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([storeId, rack, shelf, bin])
  @@map("storelocation")
}

// ═══════════════════════════════════════════════════════
// ROOT CAUSE ANALYSIS — 5 Whys + 6M structured framework
// ═══════════════════════════════════════════════════════
model RootCauseAnalysis {
  id       Int    @id @default(autoincrement())
  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  workOrderId Int?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])

  framework        String // FIVE_WHYS | SIX_M | COMBINED
  summary          String? @db.Text
  conclusion       String? @db.Text
  correctiveAction String? @db.Text
  preventiveAction String? @db.Text

  performedById Int?
  performedAt   DateTime?
  status        String    @default("DRAFT") // DRAFT | COMPLETED | REVIEWED

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  fiveWhys  RcaFiveWhy[]
  sixMItems RcaSixMItem[]

  @@index([ticketId])
  @@map("rootcauseanalysis")
}

model RcaFiveWhy {
  id    Int               @id @default(autoincrement())
  rcaId Int
  rca   RootCauseAnalysis @relation(fields: [rcaId], references: [id])

  whyNumber Int
  question  String @db.Text
  answer    String @db.Text

  @@index([rcaId])
  @@map("rcafivewhy")
}

model RcaSixMItem {
  id    Int               @id @default(autoincrement())
  rcaId Int
  rca   RootCauseAnalysis @relation(fields: [rcaId], references: [id])

  category String // MAN | MACHINE | MATERIAL | METHOD | MEASUREMENT | MOTHER_NATURE
  cause    String  @db.Text
  isRoot   Boolean @default(false)

  @@index([rcaId])
  @@map("rcasixmitem")
}

// ═══════════════════════════════════════════════════════
// PURCHASE ORDER — Separate procurement module
// ═══════════════════════════════════════════════════════
model PurchaseOrder {
  id       Int      @id @default(autoincrement())
  poNumber String   @unique
  poDate   DateTime @default(now())

  vendorId Int
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  status String @default("DRAFT") // DRAFT | SUBMITTED | HOD_APPROVED | MGMT_APPROVED | SENT_TO_VENDOR | PARTIALLY_RECEIVED | FULLY_RECEIVED | CANCELLED | CLOSED

  // Optional linkage to indent
  indentId Int?
  indent   AssetIndent? @relation(fields: [indentId], references: [id])

  departmentId Int?
  department   Department? @relation("PODepartment", fields: [departmentId], references: [id])

  // Financial
  subtotal    Decimal? @db.Decimal(14, 2)
  taxAmount   Decimal? @db.Decimal(14, 2)
  totalAmount Decimal? @db.Decimal(14, 2)
  currency    String   @default("INR")

  // Approval chain (amount-based routing)
  hodApprovedById   Int?
  hodApprovedAt     DateTime?
  hodRemarks        String?   @db.Text
  mgmtApprovedById  Int?
  mgmtApprovedAt    DateTime?
  mgmtRemarks       String?   @db.Text
  cooApprovedById   Int?
  cooApprovedAt     DateTime?
  cooRemarks        String?   @db.Text
  cfoApprovedById   Int?
  cfoApprovedAt     DateTime?
  cfoRemarks        String?   @db.Text
  approvalLevel     String?   // HOD | MANAGEMENT | COO | CFO — highest level needed based on amount

  // Amendment tracking
  amendmentCount    Int       @default(0)
  isAmended         Boolean   @default(false)
  originalAmount    Decimal?  @db.Decimal(14, 2)

  deliveryDate    DateTime?
  paymentTerms    String?   @db.Text
  shippingAddress String?   @db.Text
  notes           String?   @db.Text

  createdById Int?
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  lines         PurchaseOrderLine[]
  goodsReceipts GoodsReceipt[]
  assets        Asset[]             @relation("POAssets")
  amendments    PurchaseOrderAmendment[]

  @@index([vendorId])
  @@index([status])
  @@index([indentId])
  @@map("purchaseorder")
}

model PurchaseOrderAmendment {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  amendmentNumber Int           // 1, 2, 3...
  reason          String        @db.Text
  previousAmount  Decimal       @db.Decimal(14, 2)
  newAmount       Decimal       @db.Decimal(14, 2)
  changeAmount    Decimal       @db.Decimal(14, 2) // newAmount - previousAmount (can be negative)

  // Snapshot of what changed
  changesJson     Json?         // { linesAdded: [], linesModified: [], linesRemoved: [] }

  status          String        @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedById    Int?
  approvedAt      DateTime?
  remarks         String?       @db.Text

  createdById     Int?
  createdAt       DateTime      @default(now())

  @@index([purchaseOrderId])
  @@map("purchaseorderamendment")
}

model PurchaseOrderLine {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  lineNumber  Int
  itemType    String // ASSET | SPARE_PART | CONSUMABLE | SERVICE
  description String

  assetCategoryId Int?
  sparePartId     Int?
  consumableId    Int?

  storeId Int?
  store   Store? @relation("POLineStore", fields: [storeId], references: [id])

  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  taxPercent Decimal? @db.Decimal(5, 2)
  lineTotal  Decimal  @db.Decimal(14, 2)

  receivedQty Int  @default(0)
  pendingQty  Int?

  hsnCode        String?
  specifications String? @db.Text

  createdAt DateTime @default(now())

  goodsReceiptLines GoodsReceiptLine[]

  @@index([purchaseOrderId])
  @@map("purchaseorderline")
}

// ═══════════════════════════════════════════════════════
// GOODS RECEIPT (GRA/GRN) — Receipt and inspection
// ═══════════════════════════════════════════════════════
model GoodsReceipt {
  id        Int      @id @default(autoincrement())
  grnNumber String   @unique
  grnDate   DateTime @default(now())

  purchaseOrderId Int?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  vendorId Int?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  status String @default("DRAFT") // DRAFT | INSPECTION_PENDING | INSPECTION_PASSED | INSPECTION_FAILED | ACCEPTED | PARTIALLY_ACCEPTED | REJECTED

  inspectedById     Int?
  inspectedAt       DateTime?
  inspectionRemarks String?   @db.Text

  deliveryChallanNo String?
  deliveryDate      DateTime?
  receivedById      Int?

  invoiceNumber String?
  invoiceDate   DateTime?
  invoiceValue  Decimal?  @db.Decimal(14, 2)

  totalValue Decimal? @db.Decimal(14, 2)
  notes      String?  @db.Text

  createdById Int?
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  lines  GoodsReceiptLine[]
  assets Asset[]            @relation("GRAAssets")

  @@index([purchaseOrderId])
  @@index([status])
  @@map("goodsreceipt")
}

model GoodsReceiptLine {
  id             Int          @id @default(autoincrement())
  goodsReceiptId Int
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])

  poLineId Int?
  poLine   PurchaseOrderLine? @relation(fields: [poLineId], references: [id])

  itemType    String // ASSET | SPARE_PART | CONSUMABLE
  description String

  receivedQty Int
  acceptedQty Int @default(0)
  rejectedQty Int @default(0)

  storeId Int?
  store   Store? @relation("GRALineStore", fields: [storeId], references: [id])

  unitPrice Decimal? @db.Decimal(12, 2)
  lineTotal Decimal? @db.Decimal(14, 2)

  inspectionStatus  String? // PASS | FAIL | PARTIAL
  inspectionRemarks String? @db.Text

  createdAssetId Int?
  serialNumber   String?

  createdAt DateTime @default(now())

  @@index([goodsReceiptId])
  @@index([poLineId])
  @@map("goodsreceiptline")
}

// ═══════════════════════════════════════════════════════
// WORK ORDER — OpEx maintenance + CapEx project works
// ═══════════════════════════════════════════════════════
model WorkOrder {
  id       Int      @id @default(autoincrement())
  woNumber String   @unique
  woDate   DateTime @default(now())
  woType   String // OPEX | CAPEX

  assetId  Int?
  asset    Asset?  @relation("AssetWorkOrders", fields: [assetId], references: [id])
  ticketId Int?
  ticket   Ticket? @relation("TicketWorkOrders", fields: [ticketId], references: [id])

  description String @db.Text
  priority    String @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL

  departmentId Int?
  assignedToId Int?

  status String @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | IN_PROGRESS | PENDING_MATERIAL | WORK_COMPLETED | WCC_ISSUED | CLOSED | CANCELLED

  // Financial
  estimatedCost Decimal? @db.Decimal(14, 2)
  actualCost    Decimal? @db.Decimal(14, 2)
  budgetCode    String?

  // CAPEX specific
  capitalizeAsAsset  Boolean @default(false)
  assetCategoryId    Int?
  capitalizedAssetId Int?

  // CapEx assets created from this WO
  capitalizedAssets Asset[] @relation("CapExAssets")

  // Approval
  approvedById    Int?
  approvedAt      DateTime?
  approvalRemarks String?   @db.Text

  // Scheduling
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?

  // Contractor / vendor
  contractorVendorId Int?
  contractorName     String?
  laborCost          Decimal? @db.Decimal(12, 2)
  nonMaterialCost    Decimal? @db.Decimal(12, 2)

  createdById Int?
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  materialIssues MaterialIssue[]
  wcc            WorkCompletionCertificate?
  rcas           RootCauseAnalysis[]

  @@index([assetId])
  @@index([ticketId])
  @@index([status])
  @@map("workorder")
}

model WorkCompletionCertificate {
  id          Int       @id @default(autoincrement())
  workOrderId Int       @unique
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  wccNumber String   @unique
  wccDate   DateTime @default(now())

  workSummary          String   @db.Text
  materialsUsedSummary String?  @db.Text
  totalLaborCost       Decimal? @db.Decimal(12, 2)
  totalMaterialCost    Decimal? @db.Decimal(12, 2)
  totalCost            Decimal? @db.Decimal(14, 2)

  qualityCheckStatus String? // PASS | FAIL | CONDITIONAL
  qualityRemarks     String? @db.Text

  certifiedById Int?
  certifiedAt   DateTime?
  acceptedById  Int?
  acceptedAt    DateTime?

  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("workcompletioncertificate")
}

model MaterialIssue {
  id          Int       @id @default(autoincrement())
  workOrderId Int
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  storeId Int
  store   Store @relation(fields: [storeId], references: [id])

  issueType    String // SPARE_PART | CONSUMABLE
  sparePartId  Int?
  sparePart    SparePart?  @relation("MaterialIssueSparePart", fields: [sparePartId], references: [id])
  consumableId Int?
  consumable   Consumable? @relation("MaterialIssueConsumable", fields: [consumableId], references: [id])
  description  String?

  quantity  Decimal  @db.Decimal(12, 2)
  unitCost  Decimal? @db.Decimal(12, 2)
  totalCost Decimal? @db.Decimal(12, 2)

  issuedById Int?
  issuedAt   DateTime @default(now())
  remarks    String?

  inventoryTransactionId Int?

  createdAt DateTime @default(now())

  @@index([workOrderId])
  @@index([storeId])
  @@map("materialissue")
}

// ═══════════════════════════════════════════════════════
// STORE STOCK & TRANSFERS — Inventory management
// ═══════════════════════════════════════════════════════
model StoreStockPosition {
  id      Int   @id @default(autoincrement())
  storeId Int
  store   Store @relation(fields: [storeId], references: [id])

  itemType     String // SPARE_PART | CONSUMABLE
  sparePartId  Int?
  consumableId Int?

  currentQty   Decimal @default(0) @db.Decimal(12, 2)
  reservedQty  Decimal @default(0) @db.Decimal(12, 2)
  availableQty Decimal @default(0) @db.Decimal(12, 2)

  reorderLevel Decimal? @db.Decimal(12, 2)
  maxLevel     Decimal? @db.Decimal(12, 2)

  lastUpdatedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([storeId, itemType, sparePartId, consumableId])
  @@index([storeId])
  @@map("storestockposition")
}

model StoreTransfer {
  id             Int    @id @default(autoincrement())
  transferNumber String @unique

  fromStoreId Int
  fromStore   Store @relation("TransferFromStore", fields: [fromStoreId], references: [id])
  toStoreId   Int
  toStore     Store @relation("TransferToStore", fields: [toStoreId], references: [id])

  toDepartmentId Int?

  status       String @default("REQUESTED") // REQUESTED | APPROVED | IN_TRANSIT | RECEIVED | CANCELLED
  transferType String // STORE_TO_STORE | STORE_TO_DEPARTMENT

  requestedById Int?
  approvedById  Int?
  receivedById  Int?

  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  receivedAt  DateTime?
  remarks     String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  items StoreTransferItem[]

  @@index([fromStoreId])
  @@index([toStoreId])
  @@map("storetransfer")
}

model StoreTransferItem {
  id              Int           @id @default(autoincrement())
  storeTransferId Int
  storeTransfer   StoreTransfer @relation(fields: [storeTransferId], references: [id])

  itemType     String // SPARE_PART | CONSUMABLE | ASSET
  sparePartId  Int?
  consumableId Int?
  assetId      Int?

  quantity    Decimal  @db.Decimal(12, 2)
  receivedQty Decimal? @db.Decimal(12, 2)
  remarks     String?

  createdAt DateTime @default(now())

  @@index([storeTransferId])
  @@map("storetransferitem")
}

// ═══════════════════════════════════════════════════════
// TCO COST ALLOCATION — Track non-standard cost types
// ═══════════════════════════════════════════════════════
model AssetCostAllocation {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation("CostAllocations", fields: [assetId], references: [id])

  costType    String // LABOR | UTILITY_POWER | SPACE_FACILITY | OUTSOURCED_SERVICE | CONSUMABLE | OTHER
  description String?
  amount      Decimal  @db.Decimal(14, 2)
  period      String? // e.g. "2025-Q1", "2025-03", "FY2025-26"
  entryDate   DateTime @default(now())

  referenceType String? // WORK_ORDER | INVOICE | MANUAL
  referenceId   Int?

  createdById Int?
  createdAt   DateTime @default(now())

  @@index([assetId, costType])
  @@map("assetcostallocation")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ASSET RATE CARD — Revenue configuration per asset
// ═══════════════════════════════════════════════════════════════════════════════
model AssetRateCard {
  id      Int   @id @default(autoincrement())
  assetId Int   @unique
  asset   Asset @relation("AssetRateCard", fields: [assetId], references: [id])

  // Revenue rate
  avgRevenuePerUnit  Decimal  @db.Decimal(12, 2) // average revenue per procedure/use/hour
  revenueUnit        String   @default("PER_USE") // PER_USE | PER_HOUR | PER_DAY | PER_PROCEDURE | PER_TEST | PER_BED_DAY
  currency           String   @default("INR")

  // Capacity configuration
  maxHoursPerDay     Decimal  @db.Decimal(5, 2) @default(24)  // max operable hours per day
  maxUsesPerDay      Int?     // max procedures/tests per day (if applicable)
  plannedHoursPerDay Decimal  @db.Decimal(5, 2) @default(8)   // planned/scheduled hours per day

  // Operating schedule
  operatingDaysPerWeek  Int   @default(6)  // 5, 6, or 7
  shiftsPerDay          Int   @default(1)  // 1, 2, or 3
  shiftDurationHours    Decimal @db.Decimal(4, 2) @default(8)

  // Benchmarks
  targetUtilizationPct  Decimal @db.Decimal(5, 2) @default(70)  // target % utilization
  targetOeeScore        Decimal @db.Decimal(5, 2) @default(80)  // target OEE score (0-100)

  // Quality metric (for OEE)
  qualityPassRatePct    Decimal @db.Decimal(5, 2) @default(98)  // % of output that meets quality standards

  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("assetratecard")
}

// ═══════════════════════════════════════════════════════════════════════════════
// DAILY USAGE LOG — End-user reports daily asset usage
// ═══════════════════════════════════════════════════════════════════════════════
model AssetDailyUsageLog {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation("DailyUsageLogs", fields: [assetId], references: [id])

  logDate    DateTime // the day being reported (DATE only, no time)

  // Usage metrics
  hoursUsed      Decimal  @db.Decimal(5, 2) // actual hours the asset was operated
  procedureCount Int?     // number of procedures/tests/uses (if applicable)
  patientsServed Int?     // number of patients (for medical equipment)

  // Shift-wise breakdown (optional granularity)
  shift1Hours    Decimal? @db.Decimal(4, 2) // morning shift hours
  shift2Hours    Decimal? @db.Decimal(4, 2) // afternoon shift hours
  shift3Hours    Decimal? @db.Decimal(4, 2) // night shift hours

  // Revenue from this day's usage
  revenueGenerated Decimal? @db.Decimal(12, 2) // actual revenue (if known)
  estimatedRevenue Decimal? @db.Decimal(12, 2) // calculated: hoursUsed * avgRevenuePerUnit (or procedureCount * rate)

  // Downtime tracking
  downtimeHours      Decimal? @db.Decimal(5, 2) @default(0)
  downtimeType       String?  // PLANNED | UNPLANNED | MAINTENANCE | CALIBRATION | NO_DEMAND | POWER_OUTAGE | STAFF_UNAVAILABLE
  downtimeRemarks    String?  @db.Text

  // OEE components (computed per day)
  availabilityPct  Decimal? @db.Decimal(5, 2) // (plannedHours - downtimeHours) / plannedHours * 100
  performancePct   Decimal? @db.Decimal(5, 2) // actualOutput / theoreticalMaxOutput * 100
  qualityPct       Decimal? @db.Decimal(5, 2) // goodOutput / totalOutput * 100
  oeeScore         Decimal? @db.Decimal(5, 2) // availability * performance * quality / 10000

  // Condition after use
  conditionAfterUse String? // GOOD | NEEDS_ATTENTION | DEGRADED | CRITICAL

  // Who logged it
  loggedById   Int?
  loggedBy     Employee? @relation("UsageLoggedBy", fields: [loggedById], references: [id])
  verifiedById Int?
  verifiedAt   DateTime?
  status       String   @default("LOGGED") // LOGGED | VERIFIED | FLAGGED

  remarks String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([assetId, logDate])
  @@index([assetId, logDate])
  @@index([loggedById])
  @@map("assetdailyusagelog")
}

model MaterialRequest {
  id         Int      @id @default(autoincrement())
  ticketId   Int
  ticket     Ticket   @relation(fields: [ticketId], references: [id])

  itemType       String   // SPARE_PART | CONSUMABLE | NEW_MATERIAL
  sparePartId    Int?
  consumableId   Int?
  description    String   @db.Text
  quantity       Decimal  @db.Decimal(12, 2)
  estimatedCost  Decimal? @db.Decimal(12, 2)

  status         String   @default("PENDING") // PENDING | OPERATIONS_APPROVED | REJECTED | DELIVERED

  // Operations approval
  approvedById      Int?
  approvedAt        DateTime?
  approvalRemarks   String?  @db.Text

  // Delivery timeframe
  expectedDelivery  DateTime?
  actualDelivery    DateTime?
  deliveryRemarks   String?

  requestedById  Int?
  requestedAt    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([ticketId])
  @@index([status])
  @@map("materialrequest")
}

model ApprovalConfig {
  id         Int    @id @default(autoincrement())
  module     String // PURCHASE_ORDER | WORK_ORDER | DISPOSAL | MATERIAL_REQUEST
  level      Int    // 1, 2, 3...
  roleName   String // HOD | OPERATIONS | FINANCE | CEO_COO | ADMIN
  minAmount  Decimal @db.Decimal(14, 2) // from this amount
  maxAmount  Decimal? @db.Decimal(14, 2) // up to this amount (null = unlimited)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([module, level])
  @@map("approvalconfig")
}
