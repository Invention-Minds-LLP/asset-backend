/**
 * =========================
 * NEW: AMC/CMC contracts
 * =========================
 */
model ServiceContract {
  id Int @id @default(autoincrement())

  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  vendorId Int?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  contractType   String // AMC | CMC
  contractNumber String?

  startDate DateTime
  endDate   DateTime

  includesParts Boolean? // typically false for AMC, true for CMC
  includesLabor Boolean?

  visitsPerYear          Int? // kept for backward compat
  regularVisitsPerYear   Int? // planned preventive maintenance visits
  emergencyVisitsPerYear Int? // emergency call-out visits included
  cost                   Decimal? @db.Decimal(12, 2) // If free/warranty, keep null or 0
  currency               String?

  document String?
  terms    String? @db.Text

  status String? // ACTIVE | EXPIRED | TERMINATED

  // Vendor SLA commitments (contractual)
  vendorResponseValue   Int? // e.g. 4
  vendorResponseUnit    String? // HOURS | DAYS
  vendorResolutionValue Int? // e.g. 24
  vendorResolutionUnit  String? // HOURS | DAYS

  createdBy String?
  reason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  maintenanceHistories MaintenanceHistory[]
  serviceVisits        ServiceVisit[]

  @@index([assetId, endDate])
  @@map("servicecontract")
}

/**
 * =========================
 * NEW: Service Visit (individual visits logged under a contract)
 * =========================
 */
model ServiceVisit {
  id                Int             @id @default(autoincrement())
  serviceContractId Int
  serviceContract   ServiceContract @relation(fields: [serviceContractId], references: [id])

  assetId Int
  asset   Asset @relation("AssetServiceVisits", fields: [assetId], references: [id])

  visitType   String // PREVENTIVE_MAINTENANCE | REPAIR
  visitDate   DateTime
  visitedById Int?
  visitedBy   Employee? @relation("ServiceVisitEngineer", fields: [visitedById], references: [id])

  workDone      String? @db.Text
  partsReplaced String? @db.Text
  outcome       String? // RESOLVED | PENDING_PARTS | ESCALATED

  // Chargeable logic
  isChargeable         Boolean   @default(false)
  chargeableReason     String? // NO_WARRANTY | NO_CONTRACT | ACCIDENTAL_DAMAGE
  chargeAmount         Decimal?  @db.Decimal(10, 2)
  chargeApprovalStatus String? // PENDING | APPROVED | REJECTED (for amounts > 1000)
  chargeApprovedById   Int?
  chargeApprovedBy     Employee? @relation("ServiceVisitChargeApprover", fields: [chargeApprovedById], references: [id])
  chargeApprovedAt     DateTime?

  createdById Int?
  createdBy   Employee? @relation("ServiceVisitCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@map("servicevisit")
}

/**
 * =========================
 * NEW: Gate Pass
 * =========================
 */
model GatePass {
  id         Int    @id @default(autoincrement())
  gatePassNo String @unique

  type   String // RETURNABLE | NON_RETURNABLE
  status String // ISSUED | RETURNED | CLOSED | CANCELLED

  assetId Int?
  asset   Asset? @relation(fields: [assetId], references: [id])

  description String?
  quantity    Int?

  issuedTo           String
  purpose            String
  expectedReturnDate DateTime?

  courierDetails String?
  vehicleNo      String?
  vehicleType    String? // HOSPITAL_VEHICLE | OUTSIDE_VEHICLE

  approvedBy         String?
  issuedBy           String?
  approvedById       Int?
  approvedByEmployee Employee? @relation("GatePassApprover", fields: [approvedById], references: [id])

  // Return tracking
  returnedAt      DateTime?
  returnedBy      String?
  returnCondition String? // GOOD | DAMAGED | PARTIAL

  reason String?

  // Auto-generated from transfer
  transferHistoryId Int?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  notifications Notification[]

  @@index([assetId, createdAt])
  @@map("gatepass")
}

/**
 * =========================
 * NEW: Spares + Consumables
 * =========================
 */
model SparePart {
  id   Int    @id @default(autoincrement())
  name String

  partNumber String?
  model      String?
  category   String? // e.g., MONITOR, VENTILATOR, GENERAL

  vendorId Int?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  stockQuantity Int      @default(0)
  reorderLevel  Int?     @default(0)
  cost          Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  createdById Int?
  updatedById Int?

  usages               SparePartUsage[]
  transactions         InventoryTransaction[]
  subAssetReplacements SubAssetReplacement[]
  materialIssues       MaterialIssue[]  @relation("MaterialIssueSparePart")

  @@index([vendorId])
  @@map("sparepart")
}

// Tracks when a sub-asset (component) is replaced — either with a new part or from inventory
model SubAssetReplacement {
  id Int @id @default(autoincrement())

  parentAssetId Int
  parentAsset   Asset @relation("ParentOfReplacement", fields: [parentAssetId], references: [id])

  oldSubAssetId Int?
  oldSubAsset   Asset? @relation("OldSubAsset", fields: [oldSubAssetId], references: [id])

  newSubAssetId Int?
  newSubAsset   Asset? @relation("NewSubAsset", fields: [newSubAssetId], references: [id])

  // If replaced from spare part inventory (not creating a new asset record)
  sparePartId Int?
  sparePart   SparePart? @relation(fields: [sparePartId], references: [id])

  replacementDate DateTime  @default(now())
  reason          String?   @db.Text
  cost            Decimal?  @db.Decimal(12, 2)
  replacedById    Int?
  replacedBy      Employee? @relation(fields: [replacedById], references: [id])
  notes           String?   @db.Text

  createdAt DateTime @default(now())

  @@index([parentAssetId])
  @@map("subassetreplacement")
}

model SparePartUsage {
  id Int @id @default(autoincrement())

  sparePartId Int
  sparePart   SparePart @relation(fields: [sparePartId], references: [id])

  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  ticketId Int?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  quantity  Int
  costAtUse Decimal? @db.Decimal(12, 2)

  usedById Int?
  usedBy   Employee? @relation(fields: [usedById], references: [id])

  reason String?

  usedAt DateTime @default(now())

  @@index([assetId, usedAt])
  @@map("sparepartusage")
}

model Consumable {
