  transfersTo   AssetTransferHistory[] @relation("ToBranch")

  createdById Int?
  updatedById Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("branch")
}

model AssetLocation {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  block              String?
  floor              String?
  room               String?
  departmentSnapshot String?

  employeeResponsibleId Int?
  employeeResponsible   Employee? @relation(fields: [employeeResponsibleId], references: [id])

  isActive Boolean @default(true)
  status   String  @default("REQUESTED") // REQUESTED | APPROVED | REJECTED

  requestedById Int?
  requestedBy   Employee? @relation("LocationRequestedBy", fields: [requestedById], references: [id])

  approvedById Int?
  approvedBy   Employee? @relation("LocationApprovedBy", fields: [approvedById], references: [id])

  rejectedById Int?
  rejectedBy   Employee? @relation("LocationRejectedBy", fields: [rejectedById], references: [id])

  requestReason   String?
  approvalReason  String?
  rejectionReason String?

