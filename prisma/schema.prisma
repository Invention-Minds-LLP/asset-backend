  host      String
  port      Int
  secure    Boolean @default(true)
  username  String
  password  String
  fromName  String  @default("Smart Assets")
  fromEmail String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("smtpconfig")
}

model AssetAssignment {
