// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AssignmentStatus {
  PENDING
  ACKNOWLEDGED
  REJECTED
  RETURNED
}

enum AssignmentAction {
  CREATED
  ACKNOWLEDGED
  REJECTED
  REASSIGNED
  RETURNED
}

enum EmployeeRole {
  CEO_COO
  HOD
  SUPERVISOR
  EXECUTIVE
  FINANCE
  OPERATIONS
}

enum AssignmentStage {
  HOD_SOURCE
  SUPERVISOR
  HOD_TARGET
  END_USER
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  WORK_COMPLETED
  RESOLVED
  TERMINATED
  CLOSED
  REJECTED
}

enum TicketAssignmentAction {
  ASSIGNED
  REASSIGNED
  UNASSIGNED
}

enum ChecklistRunStatus {
  DUE
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ChecklistResult {
  PASS
  FAIL
  NA
}

enum TicketTransferType {
  INTERNAL_DEPARTMENT
  EXTERNAL_VENDOR
  EXTERNAL_SERVICE
}

enum TicketTransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum AssetSlaCategory {
  LOW
  MEDIUM
  HIGH
}

enum SlaLevel {
  L1
  L2
  L3
}

enum AcknowledgementPurpose {
  ASSIGNMENT
  TRANSFER_RETURN
  TRANSFER_OUT
  MAINTENANCE
}

model Asset {
  id                Int           @id @default(autoincrement())
  assetId           String        @unique
  assetName         String
  assetType         String
  assetCategoryId   Int
  assetCategory     AssetCategory @relation(fields: [assetCategoryId], references: [id])
  serialNumber      String        @unique
  purchaseDate      DateTime?
  modeOfProcurement String        @default("PURCHASE") // PURCHASE | DONATION | LEASE | RENTAL 

  manufacturer       String?
  modelNumber        String?
  countryOfOrigin    String?
  regulatoryApproval String? // FDA/CE/BIS certification number

  referenceCode String?  @unique
  isBranded     Boolean? @default(false)
  isAssembled   Boolean? @default(false)
  isCustomized  Boolean? @default(false)
  customDetails String?  @db.Text

  hasSpecifications Boolean? @default(false)
  physicalCondition String? // EXCELLENT | GOOD | FAIR | POOR

  installedAt DateTime?

  // PURCHASE
  invoiceNumber     String?
  purchaseOrderNo   String?
  purchaseOrderDate DateTime?
  deliveryDate      DateTime?
  purchaseCost      Decimal?  @db.Decimal(12, 2)

  // DONATION
  donorName        String?
  donationDate     DateTime?
  assetCondition   String? // NEW / USED
  estimatedValue   Decimal?  @db.Decimal(12, 2)
  donationDocument String?

  // LEASE
  leaseStartDate   DateTime?
  leaseEndDate     DateTime?
  leaseAmount      Decimal?  @db.Decimal(12, 2)
  leaseRenewalDate DateTime?
  leaseContractDoc String?

  // RENTAL
  rentalStartDate    DateTime?
  rentalEndDate      DateTime?
  rentalAmount       Decimal?  @db.Decimal(12, 2)
  rentalAgreementDoc String?

  // Physical + Functional Inspection (for Donation / Lease / Rental)
  inspectionDoneBy           String? // who performed the inspection
  inspectionCondition        String? // SEALED | UNSEALED | DAMAGED | GOOD | FAIR
  inspectionRemark           String?   @db.Text
  physicalInspectionStatus   String? // PASS | FAIL | PENDING
  physicalInspectionDate     DateTime?
  functionalInspectionStatus String? // PASS | FAIL | PENDING
  functionalInspectionDate   DateTime?
  functionalTestNotes        String?   @db.Text

  vendorId Int?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  // GRN
  grnNumber         String?
  grnDate           DateTime?
  grnValue          Decimal?  @db.Decimal(12, 2)
  inspectionStatus  String?
  inspectionRemarks String?

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  targetDepartmentId Int? // NEW (where end user belongs)
  targetDepartment   Department? @relation("TargetDept", fields: [targetDepartmentId], references: [id])

  supervisorId Int?
  supervisor   Employee? @relation("AssetSupervisor", fields: [supervisorId], references: [id])

  allottedToId    Int?
  allottedTo      Employee? @relation("AssetEndUser", fields: [allottedToId], references: [id])
  rfidCode        String?   @unique
  qrCode          String?   @unique
  qrGeneratedAt   DateTime?
  qrLabelPrinted  Boolean?  @default(false)
  currentLocation String?
  fromLocation    String?
  toLocation      String?
  status          String
  assetPhoto      String?

  sourceType         String? // NEW | INVENTORY
  sourceReference    String?
  remarks            String?           @db.Text
  // Hospital-critical classification (optional)
  criticalityLevel   String? // LOW | MEDIUM | HIGH | LIFE_SUPPORT
  riskClass          String? // CLASS_I | CLASS_II | CLASS_III
  // Condition/health (optional)
  workingCondition   String? // WORKING | PARTIAL | NOT_WORKING
  healthScore        Int?
  lastInspectionDate DateTime?
  slaExpectedValue   Int?
  slaExpectedUnit    String?
  slaResolutionValue Int?
  slaResolutionUnit  String?
  slaNextDueAt       DateTime?
  slaBreached        Boolean?
  slaCategory        AssetSlaCategory?
  lastSlaServiceDate DateTime?

  // Audit / verification
  lastAuditDate  DateTime?
  auditedBy      String?
  warrantyStatus String? // UNDER_WARRANTY | EXPIRED | NO_WARRANTY

  // Retirement / disposal
  retiredDate          DateTime?
  retiredReason        String?
  expectedLifetime     Int?
  expectedLifetimeUnit String?
  // Service coverage type (e.g. 24/7, 8/5, 9/6)
  serviceCoverageType  String? // 24/7 | 8/5 | 9/6 | 12/7 | CUSTOM
  // HOD approval tracking before Asset ID is issued
  hodApprovalStatus    String? // PENDING | APPROVED | REJECTED
  hodApprovalById      Int?
  hodApprovalAt        DateTime?
  hodApprovalRemarks   String?   @db.Text
  retiredBy            String?
  disposalMethod       String? // SOLD | SCRAPPED | DONATED | RETURNED_TO_VENDOR | AUCTION
  disposalValue        Decimal?  @db.Decimal(12, 2)
  disposalDate         DateTime?
  disposalApprovedBy   String?
  disposalCertificate  String? // URL for certificate of destruction

  // Sub-assets (optional hierarchy)
  parentAssetId Int?
  parentAsset   Asset?  @relation("SubAssets", fields: [parentAssetId], references: [id])
  subAssets     Asset[] @relation("SubAssets")

  replacedBySubAsset  SubAssetReplacement[] @relation("OldSubAsset")
  replacingSubAsset   SubAssetReplacement[] @relation("NewSubAsset")
  parentOfReplacement SubAssetReplacement[] @relation("ParentOfReplacement")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  createdById Int?
  updatedById Int?

  specificationSummary String? @db.Text
  organogramNotes      String? @db.Text
  ticketHierarchyNotes String? @db.Text
  pmFormatNotes        String? @db.Text

  depreciation AssetDepreciation?
  insurance    AssetInsurance[]
  locations    AssetLocation[]
  transfers    AssetTransferHistory[]

  maintenanceHistory MaintenanceHistory[]

  warranties                   Warranty[]
  tickets                      Ticket[]
  serviceContracts             ServiceContract[]
  serviceDocuments             Document[]
  qrScans                      QRScanLog[]
  gatePasses                   GatePass[]
  scanLogs                     AssetScanLog[]
  notifications                Notification[]
  assignments                  AssetAssignment[]
  specifications               AssetSpecification[]
  employee                     Employee?                      @relation(fields: [employeeId], references: [id])
  employeeId                   Int?
  depreciationLogs             DepreciationLog[]
  insuranceClaims              InsuranceClaim[]
  maintenanceSchedules         MaintenanceSchedule[]
  sparePartUsages              SparePartUsage[]
  calibrationSchedules         CalibrationSchedule[]
  calibrationHistory           CalibrationHistory[]
  preventiveChecklistTemplates PreventiveChecklistTemplate[]
  preventiveChecklistRuns      PreventiveChecklistRun[]
  acknowledgementTemplates     AssetAcknowledgementTemplate[]
  acknowledgementRuns          AssetAcknowledgementRun[]
  pmChecklistTemplates         PMChecklistTemplate[]
  pmChecklistRuns              PMChecklistRun[]
  calibrationTemplates         CalibrationChecklistTemplate[]
  supportMatrixes              AssetSupportMatrix[]
  disposals                    AssetDisposal[]
  auditItems                   AssetAuditItem[]               @relation("AuditItems")
  indentFulfillments           AssetIndent[]                  @relation("IndentFulfilledAsset")
  exitAssets                   EmployeeExitAsset[]            @relation("ExitAssets")
  serviceVisits                ServiceVisit[]                 @relation("AssetServiceVisits")
  revenueEntries               AssetRevenueEntry[]
  decisionLogs                 DecisionEngineLog[]            @relation("DecisionLogs")

  // Procurement linkage (optional — nullable FKs, Asset works without PO/GRA)
  purchaseOrderId   Int?
  purchaseOrderRef  PurchaseOrder? @relation("POAssets", fields: [purchaseOrderId], references: [id])
  goodsReceiptId    Int?
  goodsReceiptRef   GoodsReceipt?  @relation("GRAAssets", fields: [goodsReceiptId], references: [id])
  workOrderCapexId  Int?
  workOrderCapexRef WorkOrder?     @relation("CapExAssets", fields: [workOrderCapexId], references: [id])

  // Work orders on this asset
  workOrders      WorkOrder[]           @relation("AssetWorkOrders")
  costAllocations AssetCostAllocation[] @relation("CostAllocations")
  rateCard        AssetRateCard?        @relation("AssetRateCard")
  dailyUsageLogs  AssetDailyUsageLog[]  @relation("DailyUsageLogs")

  @@index([status])
  @@index([assetCategoryId])
  @@index([departmentId])
  @@index([vendorId])
  @@map("asset")
}

model Warranty {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  warrantyStart   DateTime
  warrantyEnd     DateTime
  daysToExpiry    Int?
  isUnderWarranty Boolean
  alertSent       Boolean  @default(false)

  warrantyType      String? // OEM | EXTENDED | SELLER | SERVICE | OTHER
  warrantyProvider  String?
  vendorId          Int?
  vendor            Vendor? @relation(fields: [vendorId], references: [id])
  warrantyReference String?
  coverageDetails   String? @db.Text
  exclusions        String? @db.Text
  supportContact    String?
  supportEmail      String?
  termsUrl          String?
  remarks           String? @db.Text

  createdById Int?
  updatedById Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([assetId])
  @@index([assetId, isActive])
  @@map("warranty")
}

model Ticket {
  id           Int        @id @default(autoincrement())
  ticketId     String     @unique
  raisedById   Int?
  raisedBy     Employee?  @relation("TicketRaisedBy", fields: [raisedById], references: [id])
  departmentId Int
  department   Department @relation("TicketDepartment", fields: [departmentId], references: [id])
  assetId      Int
  asset        Asset      @relation(fields: [assetId], references: [id])

  issueType    String
  detailedDesc String       @db.Text
  priority     String
  photoOfIssue String?
  location     String
  status       TicketStatus @default(OPEN)

  // ✅ assignment control
  assignedToId Int?
  assignedTo   Employee? @relation("TicketAssignedTo", fields: [assignedToId], references: [id])

  assignedById Int?
  assignedBy   Employee? @relation("TicketAssignedBy", fields: [assignedById], references: [id])

  owningDepartmentId Int?
  owningDepartment   Department? @relation("TicketOwningDept", fields: [owningDepartmentId], references: [id])

  // ✅ transfer control
  isTransferred Boolean @default(false)
  transferCount Int     @default(0) // optional (if you want to limit)

  reassignCount  Int       @default(0) // max 2
  lastAssignedAt DateTime?
  assignmentNote String?   @db.Text

  // ✅ termination by HOD
  terminatedAt    DateTime?
  terminatedById  Int?
  terminationNote String?   @db.Text

  // ✅ closing by raised person
  closedAt     DateTime?
  closedById   Int?
  closeRemarks String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  slaCategory     AssetSlaCategory?
  currentSlaLevel SlaLevel?

  // Governing SLA (stricter of internal vs vendor, used for breach tracking)
  slaExpectedValue Int?
  slaExpectedUnit  String? // HOURS | DAYS
  slaResolvedAt    DateTime?
  slaBreached      Boolean?

  // SLA source tracking
  slaSource String? // INTERNAL | VENDOR | BOTH

  // Internal SLA (from AssetSlaMatrix by category + priority)
  internalSlaValue Int?
  internalSlaUnit  String?

  // Vendor SLA (from active AMC/CMC contract)
  vendorSlaValue    Int?
  vendorSlaUnit     String?
  vendorSlaBreached Boolean?

  // Asset collection by supervisor (for external service center cases)
  collectionNotes           String?   @db.Text // notes by the ticket raiser on supervisor collecting the asset
  collectedAt               DateTime?
  collectedById             Int?
  collectedBy               Employee? @relation("TicketCollectedBy", fields: [collectedById], references: [id])
  collectionHandoverRemarks String?   @db.Text

  // Ticket work category (PM vs Breakdown — determines asset status flow)
  workCategory String? // PREVENTIVE_MAINTENANCE | BREAKDOWN | CORRECTIVE | CALIBRATION

  // Downtime (useful for hospital ops + finance reporting)
  downtimeStart DateTime?
  downtimeEnd   DateTime?

  // Cost capture (so finance excel is possible without a ledger module)
  serviceType String? // WARRANTY | AMC | CMC | PAID | INTERNAL
  serviceCost Decimal? @db.Decimal(12, 2)
  partsCost   Decimal? @db.Decimal(12, 2)
  totalCost   Decimal? @db.Decimal(12, 2)

  // Resolution knowledge
  rootCause            String?   @db.Text
  resolutionSummary    String?   @db.Text
  customerSatisfaction Int? // 1-5 feedback rating
  followUpDate         DateTime?

  // Closure / approvals (who/why)
  approvedBy     String?
  closedBy       String?
  closureRemarks String?

  createdById   Int?
  updatedById   Int?
  statusHistory TicketStatusHistory[]

  sparePartUsages SparePartUsage[]

  notifications             Notification[]
  ticketEscalations         TicketEscalation[]
  ticketAssignmentHistories TicketAssignmentHistory[]
  maintenanceHistories      MaintenanceHistory[]
  ticketTransferHistories   TicketTransferHistory[]
  rootCauseAnalyses         RootCauseAnalysis[]
  materialRequests          MaterialRequest[]
  workOrders                WorkOrder[]               @relation("TicketWorkOrders")

  @@index([assetId, createdAt])
  @@index([departmentId, status])
  @@map("ticket")
}

model TicketAssignmentHistory {
  id Int @id @default(autoincrement())

  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  fromEmployeeId Int?
  fromEmployee   Employee? @relation("TicketAssignFrom", fields: [fromEmployeeId], references: [id])

  toEmployeeId Int?
  toEmployee   Employee? @relation("TicketAssignTo", fields: [toEmployeeId], references: [id])

  action  TicketAssignmentAction
  comment String                 @db.Text // ✅ mandatory on every assign/reassign

  performedById Int?
  performedBy   Employee? @relation("TicketAssignPerformedBy", fields: [performedById], references: [id])

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@map("ticketassignmenthistory")
}

model MaintenanceHistory {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  serviceContractId Int?
  serviceContract   ServiceContract? @relation(fields: [serviceContractId], references: [id])

  scheduledDue  DateTime
  actualDoneAt  DateTime?
  wasLate       Boolean
  performedBy   String
  notes         String?
  serviceReport String?
  // Cost capture for finance excel
  serviceType   String? // WARRANTY | AMC | CMC | PAID | INTERNAL
  serviceCost   Decimal?  @db.Decimal(12, 2)
  partsCost     Decimal?  @db.Decimal(12, 2)
  totalCost     Decimal?  @db.Decimal(12, 2)

  createdById Int?
  updatedById Int?

  ticketId Int?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @default(now()) @updatedAt
  preventiveChecklistRuns PreventiveChecklistRun[]

  pmChecklistRuns PMChecklistRun[]

  @@index([assetId, actualDoneAt])
  @@map("maintenancehistory")
}

model User {
  id         Int      @id @default(autoincrement())
  employeeID String   @unique
  employee   Employee @relation(fields: [employeeID], references: [employeeID])

  username     String    @unique
  passwordHash String
  role         String
  lastLogin    DateTime?

  loginHistory LoginHistory[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt

  @@map("users")
}

model LoginHistory {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  attemptedAt DateTime @default(now())
  ipAddress   String?
  userAgent   String?
  success     Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("loginhistory")
}

model AssetCategory {
  id                            Int                            @id @default(autoincrement())
  name                          String                         @unique
  code                          String?                        @unique
  description                   String?
  isActive                      Boolean                        @default(true)
  assets                        Asset[]
  createdById                   Int?
  updatedById                   Int?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @default(now()) @updatedAt
  escalationMatrixes            EscalationMatrix[]
  preventiveChecklistTemplates  PreventiveChecklistTemplate[]
  acknowledgementTemplates      AssetAcknowledgementTemplate[]
  pmChecklistTemplates          PMChecklistTemplate[]
  calibrationChecklistTemplates CalibrationChecklistTemplate[]
  supportMatrixes               AssetSupportMatrix[]
  assetSlaMatrices              AssetSlaMatrix[]
  assetIndents                  AssetIndent[]
  decisionEngineConfigs         DecisionEngineConfig[]         @relation("DecisionEngineCategory")

  @@map("assetcategory")
}

model Department {
  id                 Int                     @id @default(autoincrement())
  name               String                  @unique
  code               String?                 @unique // Short code like ICU, OT, RADIOLOGY
  parentDepartmentId Int?
  parentDepartment   Department?             @relation("DeptHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[]            @relation("DeptHierarchy")
  isActive           Boolean                 @default(true)
  assets             Asset[]
  tickets            Ticket[]                @relation("TicketDepartment")
  employees          Employee[]
  createdById        Int?
  updatedById        Int?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @default(now()) @updatedAt
  escalationMatrixes EscalationMatrix[]
  targetAssets       Asset[]                 @relation("TargetDept")
  ownedTickets       Ticket[]                @relation("TicketOwningDept")
  transferFrom       TicketTransferHistory[] @relation("TicketTransferFromDept")
  transferTo         TicketTransferHistory[] @relation("TicketTransferToDept")
  assetTransferFrom  AssetTransferHistory[]  @relation("AssetTransferFromDept")
  assetTransferTo    AssetTransferHistory[]  @relation("AssetTransferToDept")
  assetIndents       AssetIndent[]
  purchaseOrders     PurchaseOrder[]         @relation("PODepartment")

  @@map("department")
}

model Employee {
  id               Int             @id @default(autoincrement())
  name             String
  employeeID       String          @unique
  email            String?
  phone            String?
  designation      String?
  departmentId     Int?
  department       Department?     @relation(fields: [departmentId], references: [id])
  reportingToId    Int?
  reportingTo      Employee?       @relation("EmployeeReporting", fields: [reportingToId], references: [id])
  directReports    Employee[]      @relation("EmployeeReporting")
  isActive         Boolean         @default(true)
  assets           Asset[]
  user             User?
  role             EmployeeRole    @default(EXECUTIVE)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @default(now()) @updatedAt
  AssetLocation    AssetLocation[]
  supervisedAssets Asset[]         @relation("AssetSupervisor")
  allocatedAssets  Asset[]         @relation("AssetEndUser")

  qrScans       QRScanLog[]
  assetScanLogs AssetScanLog[]

  notificationsCreated Notification[] @relation("NotificationCreatedBy")
  notificationsLinked  Notification[] @relation("NotificationEmployee")

  assignedAssets              AssetAssignment[]    @relation("AssignedTo")
  assignedByAssets            AssetAssignment[]    @relation("AssignedBy")
  calibrationHistoriesCreated CalibrationHistory[] @relation("EmployeeCreatedCalibrationHistory")

  notificationRecipients   NotificationRecipient[]
  depreciationLogs         DepreciationLog[]
  sparePartUsages          SparePartUsage[]
  inventoryTransactions    InventoryTransaction[]
  documents                Document[]
  assetAssignments         AssetAssignment[]
  assetAssignmentHistories AssetAssignmentHistory[]
  escalationMatrixes       EscalationMatrix[]
  ticketEscalations        TicketEscalation[]
  preventiveChecklistRuns  PreventiveChecklistRun[]
  // Ticket reverse relations
  raisedTickets            Ticket[]                 @relation("TicketRaisedBy")
  assignedTickets          Ticket[]                 @relation("TicketAssignedTo")
  assignedByMe             Ticket[]                 @relation("TicketAssignedBy")

  // History reverse relations
  ticketAssignedFrom      TicketAssignmentHistory[] @relation("TicketAssignFrom")
  ticketAssignedTo        TicketAssignmentHistory[] @relation("TicketAssignTo")
  ticketAssignActions     TicketAssignmentHistory[] @relation("TicketAssignPerformedBy")
  ticketStatusChanges     TicketStatusHistory[]     @relation("TicketStatusChangedBy")
  ticketTransferRequested TicketTransferHistory[]   @relation("TicketTransferRequestedBy")
  ticketTransferApproved  TicketTransferHistory[]   @relation("TicketTransferApprovedBy")

  assetAcknowledgementRuns AssetAcknowledgementRun[]
  assetSupportMatrixes     AssetSupportMatrix[]
  transferRequests         AssetTransferHistory[]    @relation("TransferRequestedBy")
  transferApprovals        AssetTransferHistory[]    @relation("TransferApprovedBy")
  transferMgmtApprovals    AssetTransferHistory[]    @relation("TransferMgmtApprovedBy")
  locationRequests         AssetLocation[]           @relation("LocationRequestedBy")
  locationApprovals        AssetLocation[]           @relation("LocationApprovedBy")
  locationRejections       AssetLocation[]           @relation("LocationRejectedBy")
  modulePermissions        ModulePermission[]
  notificationPreference   NotificationPreference?

  collectedTickets            Ticket[]              @relation("TicketCollectedBy")
  gatePassesApproved          GatePass[]            @relation("GatePassApprover")
  assetIndents                AssetIndent[]         @relation("IndentRaisedBy")
  assetIndentApprovals        AssetIndent[]         @relation("IndentApprovedBy")
  employeeExits               EmployeeExit[]        @relation("ExitEmployee")
  employeeExitHandledBy       EmployeeExit[]        @relation("ExitHandledBy")
  serviceVisitsAsEngineer     ServiceVisit[]        @relation("ServiceVisitEngineer")
  serviceVisitChargeApprovals ServiceVisit[]        @relation("ServiceVisitChargeApprover")
  serviceVisitsCreated        ServiceVisit[]        @relation("ServiceVisitCreatedBy")
  subAssetReplacements        SubAssetReplacement[]
  decisionEvaluations         DecisionEngineLog[]   @relation("DecisionEvaluator")
  usageLogsRecorded           AssetDailyUsageLog[]  @relation("UsageLoggedBy")

  @@map("employee")
}

model Vendor {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  contact        String
  email          String?
  contactPerson  String?
  alternatePhone String?
  address        String?  @db.Text
  city           String?
  state          String?
  pincode        String?
  gstNumber      String?
  panNumber      String?
  vendorType     String? // OEM | DISTRIBUTOR | SERVICE_PROVIDER | RESELLER
  rating         Int? // 1-5 performance rating
  isActive       Boolean  @default(true)
  bankName       String?
  bankAccount    String?
  bankIfsc       String?
  assets         Asset[]
  createdById    Int?
  updatedById    Int?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  serviceContracts ServiceContract[]
  spareParts       SparePart[]

  calibrationSchedules    CalibrationSchedule[]   @relation("VendorCalibrationSchedule")
  calibrationHistories    CalibrationHistory[]    @relation("VendorCalibrationHistory")
  ticketTransferHistories TicketTransferHistory[]
  warranties              Warranty[]
  purchaseOrders          PurchaseOrder[]
  goodsReceipts           GoodsReceipt[]

  @@map("vendor")
}

model TicketStatusHistory {
  id        Int          @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket       @relation(fields: [ticketId], references: [id])
  status    TicketStatus
  changedAt DateTime     @default(now())
  changedBy String

  note String? @db.Text

  changedById       Int?
  changedByEmployee Employee? @relation("TicketStatusChangedBy", fields: [changedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("ticketstatushistory")
}

model AssetDepreciation {
  id      Int   @id @default(autoincrement())
  assetId Int   @unique
  asset   Asset @relation(fields: [assetId], references: [id])

  depreciationMethod String // SL | DB | OTHER
  depreciationRate   Decimal   @db.Decimal(12, 2)
  expectedLifeYears  Int
  salvageValue       Decimal?  @db.Decimal(12, 2)
  depreciationStart  DateTime
  lastCalculatedAt   DateTime?

  // Added for finance reporting
  accumulatedDepreciation Decimal? @db.Decimal(12, 2)
  currentBookValue        Decimal? @db.Decimal(12, 2)
  depreciationFrequency   String? // MONTHLY | YEARLY
  isActive                Boolean? @default(true)

  createdById Int?
  updatedById Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("assetdepreciation")
}

model DepreciationLog {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  periodStart        DateTime
  periodEnd          DateTime
