// ═══════════════════════════════════════════════════════
// DECISION ENGINE — Configurable thresholds per category
// ═══════════════════════════════════════════════════════
model DecisionEngineConfig {
  id Int @id @default(autoincrement())

  // Scope — NULL means global default; set categoryId for per-category overrides
  categoryId Int?           @unique
  category   AssetCategory? @relation("DecisionEngineCategory", fields: [categoryId], references: [id])

  // Signal weights (must sum to 100)
  weightMaintenanceRatio Int @default(30)
  weightAgeFactor        Int @default(20)
  weightBreakdownFreq    Int @default(20)
  weightDowntimeImpact   Int @default(15)
  weightCostTrend        Int @default(15)

  // Decision thresholds (composite score ranges)
  thresholdMonitor Int @default(36) // score >= this → MONITOR
  thresholdReview  Int @default(56) // score >= this → REVIEW_FOR_REPLACEMENT
  thresholdReplace Int @default(76) // score >= this → REPLACE_IMMEDIATELY

  // Signal-specific tuning
  maintenanceRatioCeiling Float @default(1.5) // maintenance/bookValue ratio that maps to score 100
  breakdownHighPerYear    Int   @default(6) // breakdowns/year that maps to score 100
  downtimeHighHours       Int   @default(720) // hours/year downtime that maps to score 100
  costTrendHighPct        Float @default(50) // YoY cost increase % that maps to score 100

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("decision_engine_config")
}

// Decision engine evaluation log — stores each run result for auditing
model DecisionEngineLog {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation("DecisionLogs", fields: [assetId], references: [id])

  // Individual signal scores (0–100)
  scoreMaintenanceRatio Float
  scoreAgeFactor        Float
  scoreBreakdownFreq    Float
  scoreDowntimeImpact   Float
  scoreCostTrend        Float
  compositeScore        Float

  decision String // CONTINUE_MAINTENANCE | MONITOR | REVIEW_FOR_REPLACEMENT | REPLACE_IMMEDIATELY

  // Snapshot of key data at evaluation time
  maintenanceCost   Float
  bookValue         Float
  assetAgeYears     Float
  expectedLifeYears Float
  breakdownCount12m Int
  downtimeHours12m  Float
  costTrendPct      Float?

  reasons Json // string[] — human-readable reasons

  evaluatedAt   DateTime  @default(now())
  evaluatedById Int?
  evaluatedBy   Employee? @relation("DecisionEvaluator", fields: [evaluatedById], references: [id])

  @@index([assetId, evaluatedAt])
  @@map("decision_engine_log")
}

