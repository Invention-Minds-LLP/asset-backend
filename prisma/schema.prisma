model AssetTransferHistory {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  transferType String // INTERNAL | EXTERNAL

  // INTERNAL DETAILS
  block String?
  floor String?
  room  String?

  // EXTERNAL DETAILS
  externalType String? // BRANCH | SERVICE | DEAD

  // FROM branch (nullable for first move)
  fromBranchId Int?
  fromBranch   Branch? @relation("FromBranch", fields: [fromBranchId], references: [id])

  // TO branch (required)
  toBranchId Int?
  toBranch   Branch? @relation("ToBranch", fields: [toBranchId], references: [id])

  // Department-level transfer tracking
  fromDepartmentId Int?
  fromDepartment   Department? @relation("AssetTransferFromDept", fields: [fromDepartmentId], references: [id])
  toDepartmentId   Int?
  toDepartment     Department? @relation("AssetTransferToDept", fields: [toDepartmentId], references: [id])

  destinationType          String? // BRANCH | VENDOR | SERVICE_CENTER | EVENT | CAMP | PATIENT_HOME | OTHER
  destinationName          String?
  destinationAddress       String?
  destinationContactPerson String?
  destinationContactNumber String?

  temporary Boolean   @default(false)
  expiresAt DateTime?

  transferDate DateTime? @default(now())

  status String @default("REQUESTED")

  // Management approval — required when temporary=false (permanent transfer)
  managementApprovalStatus String?
  managementApprovedById   Int?
  managementApprovedBy     Employee? @relation("TransferMgmtApprovedBy", fields: [managementApprovedById], references: [id])
  managementApprovedAt     DateTime?
  managementRemarks        String?   @db.Text

  requestedById Int?
  requestedBy   Employee? @relation("TransferRequestedBy", fields: [requestedById], references: [id])

  approvedById Int?
  approvedBy   Employee? @relation("TransferApprovedBy", fields: [approvedById], references: [id])

  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  rejectedAt  DateTime?
  returnedAt  DateTime?

  approvalReason  String? @db.Text
  rejectionReason String? @db.Text
  returnReason    String? @db.Text
  reason          String?

  parentTransferId Int?
  parentTransfer   AssetTransferHistory?  @relation("TransferParent", fields: [parentTransferId], references: [id])
  returnEntries    AssetTransferHistory[] @relation("TransferParent")

  createdAt                DateTime                  @default(now())
  assetAcknowledgementRuns AssetAcknowledgementRun[] @relation("TransferAcknowledgementRuns")

  @@map("assettransferhistory")
}

/**
 * =========================
 * NEW: Maintenance schedule automation
 * =========================
 */
model MaintenanceSchedule {
