// ═══════════════════════════════════════════════════════════════════════════════
// NEW: Asset Disposal — formal condemnation/disposal workflow
// ═══════════════════════════════════════════════════════════════════════════════
model AssetDisposal {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  disposalType String // CONDEMN | AUCTION | SCRAP | DONATE | RETURN_TO_VENDOR
  reason       String @db.Text
  status       String @default("REQUESTED") // REQUESTED | COMMITTEE_REVIEW | APPROVED | REJECTED | COMPLETED

  estimatedScrapValue Decimal? @db.Decimal(12, 2)
  actualSaleValue     Decimal? @db.Decimal(12, 2)
  bookValueAtDisposal Decimal? @db.Decimal(12, 2) // current book value when disposal was requested
  netGainLoss         Decimal? @db.Decimal(12, 2) // actualSaleValue - bookValueAtDisposal
  buyerName           String?
  buyerContact        String?

  // Committee approval
  committeeMembers      String?   @db.Text // JSON array of approver names/IDs
  committeeRemarks      String?   @db.Text
  committeeApprovalDate DateTime?

  requestedById Int?
  approvedById  Int?
  completedById Int?

  certificateUrl String? // Certificate of destruction / disposal proof
  documents      String? @db.Text // JSON array of document URLs

  requestedAt     DateTime  @default(now())
  approvedAt      DateTime?
  completedAt     DateTime?
  rejectedAt      DateTime?
  rejectionReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([assetId])
  @@index([status])
  @@map("assetdisposal")
}

