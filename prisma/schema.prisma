  action   String? // VIEW | TRANSFER | VERIFY

  scannedAt DateTime @default(now())

  @@index([assetId, scannedAt])
  @@map("qrscanlog")
}

model AssetScanLog {
  id Int @id @default(autoincrement())

  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  scannedById Int?
  scannedBy   Employee? @relation(fields: [scannedById], references: [id])

  scanType String? // RFID | QR | MANUAL
  location String?
  notes    String?

  scannedAt DateTime @default(now())

  @@index([assetId, scannedAt])
  @@map("assetscanlog")
}

model Notification {
  id Int @id @default(autoincrement())

  // What the notification is about (optional links)
  assetId Int?
  asset   Asset? @relation(fields: [assetId], references: [id])

  ticketId Int?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  gatePassId Int?
  gatePass   GatePass? @relation(fields: [gatePassId], references: [id])

  insuranceId Int?
  insurance   AssetInsurance? @relation(fields: [insuranceId], references: [id])

  claimId Int?
  claim   InsuranceClaim? @relation(fields: [claimId], references: [id])

  // Type + content
  type    String // WARRANTY_EXPIRY | INSURANCE_EXPIRY | AMC_CMC_EXPIRY | MAINTENANCE_DUE | SLA_BREACH | LOW_STOCK | GATEPASS_OVERDUE | OTHER
  title   String?
  message String  @db.Text

  // ✅ Relation 1: who created it
  createdById Int?
  createdBy   Employee? @relation("NotificationCreatedBy", fields: [createdById], references: [id])

  // ✅ Relation 2: direct employee link (optional “about/for” employee)
  employeeId Int?
  employee   Employee? @relation("NotificationEmployee", fields: [employeeId], references: [id])

  // Optional delivery metadata (still works even if you don’t implement channels now)
  priority String? // LOW | MEDIUM | HIGH | CRITICAL
  channel  String? // IN_APP | EMAIL | SMS | WHATSAPP

  // Helps you avoid duplicates from cron jobs
  dedupeKey String? @unique

  createdAt DateTime @default(now())

  recipients NotificationRecipient[]

  @@index([assetId, createdAt])
  @@index([ticketId, createdAt])
  @@map("notification")
}

model NotificationRecipient {
  id Int @id @default(autoincrement())

  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id])

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  // Read / action tracking per employee
  isRead Boolean   @default(false)
  readAt DateTime?

  // Optional: delivery tracking (good for hospitals)
  deliveryStatus String? // PENDING | SENT | FAILED
  deliveredAt    DateTime?

  createdAt DateTime @default(now())

  @@unique([notificationId, employeeId])
  @@index([employeeId, isRead, createdAt])
  @@map("notificationrecipient")
}

model NotificationPreference {
