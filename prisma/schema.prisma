model AppModule {
  id        Int     @id @default(autoincrement())
  name      String  @unique // e.g. "assets", "tickets", "calibration"
  label     String // Display name e.g. "Assets Master"
  icon      String? // PrimeNG icon class e.g. "pi pi-database"
  path      String? // Route path e.g. "/assets/view"
  sortOrder Int?    @default(0)
  isActive  Boolean @default(true)

  subItems    AppModuleItem[]
  permissions ModulePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("appmodule")
}

model AppModuleItem {
  id       Int       @id @default(autoincrement())
  moduleId Int
  module   AppModule @relation(fields: [moduleId], references: [id])

  name      String // e.g. "view", "create", "edit", "delete"
  label     String // Display name e.g. "View Assets"
  path      String? // Sub-route e.g. "/assets/view"
  icon      String?
  sortOrder Int?    @default(0)
  isActive  Boolean @default(true)

  permissions ModulePermission[]

  @@unique([moduleId, name])
  @@map("appmoduleitem")
}

model ModulePermission {
  id Int @id @default(autoincrement())

  moduleId Int?
  module   AppModule? @relation(fields: [moduleId], references: [id])

  moduleItemId Int?
  moduleItem   AppModuleItem? @relation(fields: [moduleItemId], references: [id])

  // Either role-based OR employee-specific (not both required)
  role       String? // HOD | SUPERVISOR | EXECUTIVE | ADMIN
  employeeId Int?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  canAccess Boolean @default(true)

  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([moduleId, moduleItemId, role, employeeId])
  @@index([role])
  @@index([employeeId])
  @@map("modulepermission")
}

