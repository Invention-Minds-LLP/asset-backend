model EscalationMatrix {
  id Int @id @default(autoincrement())

  // Scope (where this rule applies)
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  assetCategoryId Int?
  assetCategory   AssetCategory? @relation(fields: [assetCategoryId], references: [id])

  priority String // LOW | MEDIUM | HIGH | CRITICAL

  level Int // 1, 2, 3...

  escalateAfterValue Int
  escalateAfterUnit  String // MINUTES | HOURS

  notifyRole       String? // e.g., TECHNICIAN, HOD, ADMIN
  notifyEmployeeId Int?
  notifyEmployee   Employee? @relation(fields: [notifyEmployeeId], references: [id])

  // SLA type this rule applies to
  slaType      String? // INTERNAL | VENDOR  (null = both)
  applicableTo String? // TICKET | MAINTENANCE  (null = both)

  // Vendor contact for escalation (used when slaType=VENDOR)
  vendorContactName  String?
  vendorContactEmail String?
  vendorContactPhone String?

  createdAt DateTime @default(now())

  @@index([departmentId, assetCategoryId, priority])
}

model TicketEscalation {
