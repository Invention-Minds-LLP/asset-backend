  assetCategory   AssetCategory? @relation(fields: [assetCategoryId], references: [id])

  assetId Int?
  asset   Asset? @relation(fields: [assetId], references: [id])

  isActive Boolean @default(true)

  items CalibrationChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([assetCategoryId])
  @@index([assetId])
  @@map("calibrationchecklisttemplate")
}

model CalibrationChecklistItem {
  id Int @id @default(autoincrement())

  templateId Int
  template   CalibrationChecklistTemplate @relation(fields: [templateId], references: [id])

  title         String
  description   String? @db.Text
  expectedValue String?
  unit          String?
  sortOrder     Int     @default(0)
  isRequired    Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([templateId, sortOrder])
  @@map("calibrationchecklistitem")
}

model AssetSupportMatrix {
  id Int @id @default(autoincrement())

  assetCategoryId Int?
  assetCategory   AssetCategory? @relation(fields: [assetCategoryId], references: [id])

  assetId Int?
  asset   Asset? @relation(fields: [assetId], references: [id])

  levelNo        Int
  roleName       String?
  personName     String?
  employeeId     Int?
  employee       Employee? @relation(fields: [employeeId], references: [id])
  contactNumber  String?
  email          String?
  escalationTime Int?
  escalationUnit String? // MINUTES | HOURS | DAYS
  notes          String?   @db.Text

  createdAt DateTime @default(now())

  @@index([assetCategoryId, assetId, levelNo])
  @@map("assetsupportmatrix")
}

model AssetSlaMatrix {
  id Int @id @default(autoincrement())

  assetCategoryId Int?
  assetCategory   AssetCategory? @relation(fields: [assetCategoryId], references: [id])

  slaCategory AssetSlaCategory
  level       SlaLevel

  responseTimeValue Int
  responseTimeUnit  String

  resolutionTimeValue Int
  resolutionTimeUnit  String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("assetslamatrix")
}

// ─── Module Access Control ────────────────────────────────────────────────────

model AppModule {
  id    Int    @id @default(autoincrement())
  name  String @unique // e.g. "assets", "tickets", "calibration"
  label String          // Display name e.g. "Assets Master"
  icon  String?         // PrimeNG icon class e.g. "pi pi-database"
  path  String?         // Route path e.g. "/assets/view"
  sortOrder Int?        @default(0)
  isActive  Boolean     @default(true)

  subItems    AppModuleItem[]
  permissions ModulePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("appmodule")
}

model AppModuleItem {
  id       Int       @id @default(autoincrement())
  moduleId Int
  module   AppModule @relation(fields: [moduleId], references: [id])

  name      String  // e.g. "view", "create", "edit", "delete"
  label     String  // Display name e.g. "View Assets"
  path      String? // Sub-route e.g. "/assets/view"
  icon      String?
  sortOrder Int?    @default(0)
  isActive  Boolean @default(true)

  permissions ModulePermission[]

  @@unique([moduleId, name])
  @@map("appmoduleitem")
}

model ModulePermission {
  id           Int            @id @default(autoincrement())

  moduleId     Int?
  module       AppModule?     @relation(fields: [moduleId], references: [id])

  moduleItemId Int?
  moduleItem   AppModuleItem? @relation(fields: [moduleItemId], references: [id])

  // Either role-based OR employee-specific (not both required)
  role         String?        // HOD | SUPERVISOR | EXECUTIVE | ADMIN
  employeeId   Int?
  employee     Employee?      @relation(fields: [employeeId], references: [id])

  canAccess    Boolean @default(true)

  createdById  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([moduleId, moduleItemId, role, employeeId])
  @@index([role])
  @@index([employeeId])
  @@map("modulepermission")
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEW: Audit Log — tracks all important actions across the application
// ═══════════════════════════════════════════════════════════════════════════════
model AuditLog {
  id          Int      @id @default(autoincrement())

  entityType  String   // ASSET | TICKET | EMPLOYEE | VENDOR | DEPARTMENT | WARRANTY | INSURANCE | TRANSFER | ASSIGNMENT | GATE_PASS | SERVICE_CONTRACT
  entityId    Int
  action      String   // CREATE | UPDATE | DELETE | STATUS_CHANGE | ASSIGN | TRANSFER | APPROVE | REJECT | LOGIN | LOGOUT

  description String?  @db.Text
  oldValue    String?  @db.LongText // JSON of previous state
  newValue    String?  @db.LongText // JSON of new state

  performedBy   String?
  performedById Int?
  ipAddress     String?
  userAgent     String?

  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedById, createdAt])
  @@index([action, createdAt])
  @@map("auditlog")
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEW: Asset Disposal — formal condemnation/disposal workflow
// ═══════════════════════════════════════════════════════════════════════════════
model AssetDisposal {
  id       Int   @id @default(autoincrement())
  assetId  Int
  asset    Asset @relation(fields: [assetId], references: [id])

  disposalType   String   // CONDEMN | AUCTION | SCRAP | DONATE | RETURN_TO_VENDOR
  reason         String   @db.Text
  status         String   @default("REQUESTED") // REQUESTED | COMMITTEE_REVIEW | APPROVED | REJECTED | COMPLETED

  estimatedScrapValue Decimal? @db.Decimal(12, 2)
  actualSaleValue     Decimal? @db.Decimal(12, 2)
  buyerName           String?
  buyerContact        String?

  // Committee approval
  committeeMembers   String?  @db.Text // JSON array of approver names/IDs
  committeeRemarks   String?  @db.Text
  committeeApprovalDate DateTime?

  requestedById   Int?
  approvedById    Int?
  completedById   Int?

  certificateUrl  String?  // Certificate of destruction / disposal proof
  documents       String?  @db.Text // JSON array of document URLs

  requestedAt   DateTime  @default(now())
  approvedAt    DateTime?
  completedAt   DateTime?
  rejectedAt    DateTime?
  rejectionReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([assetId])
  @@index([status])
  @@map("assetdisposal")
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEW: Asset Verification / Physical Audit
// ═══════════════════════════════════════════════════════════════════════════════
model AssetAudit {
  id        Int      @id @default(autoincrement())
  auditName String
  auditDate DateTime
  status    String   @default("PLANNED") // PLANNED | IN_PROGRESS | COMPLETED

  departmentId Int?
  branchId     Int?

  conductedById Int?
  remarks       String? @db.Text

  totalAssets     Int @default(0)
  verifiedCount   Int @default(0)
  missingCount    Int @default(0)
  mismatchCount   Int @default(0)

  completedAt DateTime?

  items AssetAuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("assetaudit")
}

model AssetAuditItem {
  id       Int        @id @default(autoincrement())
  auditId  Int
  audit    AssetAudit @relation(fields: [auditId], references: [id])

  assetId  Int
  asset    Asset    @relation("AuditItems", fields: [assetId], references: [id])
  status   String   @default("PENDING") // PENDING | VERIFIED | MISSING | MISMATCH
  scannedAt DateTime?

  locationMatch     Boolean?
  conditionMatch    Boolean?
  actualLocation    String?
  actualCondition   String?
  remarks           String?

  verifiedById Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([auditId, status])
  @@index([assetId])
  @@map("assetaudititem")
}
