  // Type + content
  type    String // WARRANTY_EXPIRY | INSURANCE_EXPIRY | AMC_CMC_EXPIRY | MAINTENANCE_DUE | SLA_BREACH | LOW_STOCK | GATEPASS_OVERDUE | OTHER
  title   String?
  message String  @db.Text

  // ✅ Relation 1: who created it
  createdById Int?
  createdBy   Employee? @relation("NotificationCreatedBy", fields: [createdById], references: [id])

  // ✅ Relation 2: direct employee link (optional “about/for” employee)
  employeeId Int?
  employee   Employee? @relation("NotificationEmployee", fields: [employeeId], references: [id])

  // Optional delivery metadata (still works even if you don’t implement channels now)
  priority String? // LOW | MEDIUM | HIGH | CRITICAL
  channel  String? // IN_APP | EMAIL | SMS | WHATSAPP

  // Helps you avoid duplicates from cron jobs
  dedupeKey String? @unique

  createdAt DateTime @default(now())

  recipients NotificationRecipient[]

  @@index([assetId, createdAt])
  @@index([ticketId, createdAt])
  @@map("notification")
}

