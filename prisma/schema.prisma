  name String
  unit String? // e.g., ML, PCS, BOX

  stockQuantity Decimal  @default(0) @db.Decimal(12, 2)
  reorderLevel  Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  createdById Int?
  updatedById Int?

  batches        ConsumableBatch[]
  transactions   InventoryTransaction[]
  materialIssues MaterialIssue[] @relation("MaterialIssueConsumable")

  @@unique([name])
  @@map("consumable")
}

model ConsumableBatch {
  id Int @id @default(autoincrement())

  consumableId Int
  consumable   Consumable @relation(fields: [consumableId], references: [id])

  batchNumber String?
  expiryDate  DateTime?

  quantity Decimal @db.Decimal(12, 2)

  remainingQuantity Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([consumableId, expiryDate])
  @@map("consumablebatch")
}

model InventoryTransaction {
  id Int @id @default(autoincrement())

  type String // IN | OUT | ADJUSTMENT

  sparePartId Int?
  sparePart   SparePart? @relation(fields: [sparePartId], references: [id])

  consumableId Int?
  consumable   Consumable? @relation(fields: [consumableId], references: [id])

  quantity Decimal @db.Decimal(12, 2)

  referenceType String? // PURCHASE | TICKET | MANUAL | RETURN | GRA | WORK_ORDER | STORE_TRANSFER
  referenceId   Int?

  storeId         Int?
  workOrderId     Int?
  storeTransferId Int?

  performedById Int?
  performedBy   Employee? @relation(fields: [performedById], references: [id])

  notes String?

  createdAt DateTime @default(now())

  @@index([sparePartId])
  @@index([consumableId])
  @@index([storeId])
  @@map("inventorytransaction")
}

/**
 * =========================
