}

model InsuranceClaim {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  insuranceId Int
  insurance   AssetInsurance @relation(fields: [insuranceId], references: [id])

