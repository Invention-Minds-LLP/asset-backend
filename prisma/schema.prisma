  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  level Int

  escalatedAt DateTime @default(now())

  notifiedEmployeeId Int?
  notifiedEmployee   Employee? @relation(fields: [notifiedEmployeeId], references: [id])

  message String?

  createdAt DateTime @default(now())

  @@index([ticketId, level])
}

enum CalibrationResult {
  PASS
  FAIL
  NA
}

model CalibrationSchedule {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  frequencyValue Int
  frequencyUnit  String // DAYS | MONTHS | YEARS

  nextDueAt        DateTime
  lastCalibratedAt DateTime?

  isActive Boolean @default(true)

  // Optional for hospitals
  standardProcedure String? // SOP name / standard reference
  vendorId          Int?
  vendor            Vendor? @relation("VendorCalibrationSchedule", fields: [vendorId], references: [id])

  reminderDays Int?    @default(7) // remind before due date
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  histories CalibrationHistory[]

  @@index([assetId, nextDueAt])
  @@map("calibrationschedule")
}

model CalibrationHistory {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  scheduleId Int?
  schedule   CalibrationSchedule? @relation(fields: [scheduleId], references: [id])

  calibratedAt DateTime  @default(now())
  dueAt        DateTime?

