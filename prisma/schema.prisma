// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Asset {
  id                Int           @id @default(autoincrement())
  assetId           String        @unique
  assetName         String
  assetType         String
  assetCategoryId   Int
  assetCategory     AssetCategory @relation(fields: [assetCategoryId], references: [id])
  serialNumber      String        @unique
  purchaseDate      DateTime?
  modeOfProcurement String        @default("PURCHASE") // PURCHASE | DONATION | LEASE | RENTAL 

  // PURCHASE
  invoiceNumber     String?
  purchaseOrderNo   String?
  purchaseOrderDate DateTime?
  deliveryDate      DateTime?
  purchaseCost      Float?

  // DONATION
  donorName        String?
  donationDate     DateTime?
  assetCondition   String? // NEW / USED
  estimatedValue   Float?
  donationDocument String?

  // LEASE
  leaseStartDate   DateTime?
  leaseEndDate     DateTime?
  leaseAmount      Float?
  leaseRenewalDate DateTime?
  leaseContractDoc String?

  // RENTAL
  rentalStartDate    DateTime?
  rentalEndDate      DateTime?
  rentalAmount       Float?
  rentalAgreementDoc String?

  vendorId Int?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  // GRN
  grnNumber         String?
  grnDate           DateTime?
  grnValue          Float?
  inspectionStatus  String?
  inspectionRemarks String?

  departmentId       Int?
  department         Department? @relation(fields: [departmentId], references: [id])
  allottedToId       Int?
  allottedTo         Employee?   @relation(fields: [allottedToId], references: [id])
  rfidCode           String      @unique
  currentLocation    String?
  fromLocation       String?
  toLocation         String?
  status             String
  assetPhoto         String?
  slaExpectedValue   Int?
  slaExpectedUnit    String?
  slaNextDueAt       DateTime?
  slaBreached        Boolean?
  lastSlaServiceDate DateTime?

  retiredDate          DateTime?
  retiredReason        String?
  expectedLifetime     Int?
  expectedLifetimeUnit String?
  retiredBy            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  depreciation AssetDepreciation?
  insurance    AssetInsurance[]
  locations    AssetLocation[]
  transfers    AssetTransferHistory[]

  maintenanceHistory MaintenanceHistory[]

  warranty Warranty?
  tickets  Ticket[]
}

model Warranty {
  id      Int   @id @default(autoincrement())
  assetId Int   @unique
  asset   Asset @relation(fields: [assetId], references: [id])

  warrantyStart   DateTime
  warrantyEnd     DateTime
  daysToExpiry    Int?
  isUnderWarranty Boolean
  amcActive       Boolean
  amcVendor       String?
  amcStart        DateTime?
  amcEnd          DateTime?
  amcVisitsDue    Int?
  lastServiceDate DateTime?
  nextVisitDue    DateTime?
  serviceReport   String?
  alertSent       Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Ticket {
  id           Int        @id @default(autoincrement())
  ticketId     String     @unique
  raisedBy     String
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  assetId      Int
  asset        Asset      @relation(fields: [assetId], references: [id])

  issueType    String
  detailedDesc String  @db.Text
  priority     String
  photoOfIssue String?
  location     String
  status       String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  slaExpectedValue Int? // numeric value
  slaExpectedUnit  String? // e.g., "HOURS", "DAYS", "MONTHS", "YEARS"
  slaResolvedAt    DateTime?
  slaBreached      Boolean?

  statusHistory TicketStatusHistory[]
}

model MaintenanceHistory {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  scheduledDue  DateTime
  actualDoneAt  DateTime
  wasLate       Boolean
  performedBy   String
  notes         String?
  serviceReport String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model User {
  id         Int      @id @default(autoincrement())
  employeeID String   @unique
  employee   Employee @relation(fields: [employeeID], references: [employeeID])

  username     String    @unique
  passwordHash String
  role         String
  lastLogin    DateTime?

  loginHistory LoginHistory[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt
}

model LoginHistory {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  attemptedAt DateTime @default(now())
  ipAddress   String?
  userAgent   String?
  success     Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model AssetCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  assets    Asset[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  assets    Asset[]
  tickets   Ticket[]
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt
}

model Employee {
  id            Int             @id @default(autoincrement())
  name          String
  employeeID    String          @unique
  departmentId  Int?
  department    Department?     @relation(fields: [departmentId], references: [id])
  assets        Asset[]
  user          User?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  AssetLocation AssetLocation[]
}

model Vendor {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  contact   String
  email     String?
  assets    Asset[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model TicketStatusHistory {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  status    String
  changedAt DateTime @default(now())
  changedBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model AssetDepreciation {
  id      Int   @id @default(autoincrement())
  assetId Int   @unique
  asset   Asset @relation(fields: [assetId], references: [id])

  depreciationMethod String // SL | DB | OTHER
  depreciationRate   Float
  expectedLifeYears  Int
  salvageValue       Float?
  depreciationStart  DateTime
  lastCalculatedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model AssetInsurance {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  provider       String?
  policyNumber   String?
  coverageAmount Float?
  premiumAmount  Float?
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean   @default(true)

  document String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Branch {
  id   Int    @id @default(autoincrement())
  name String @unique

  locations     AssetLocation[]
  transfersFrom AssetTransferHistory[] @relation("FromBranch")
  transfersTo   AssetTransferHistory[] @relation("ToBranch")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model AssetLocation {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  block String?
  floor String?
  room  String?

  employeeResponsibleId Int?
  employeeResponsible   Employee? @relation(fields: [employeeResponsibleId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
}

model AssetTransferHistory {
  id      Int   @id @default(autoincrement())
  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  // FROM branch (nullable for first move)
  fromBranchId Int?
  fromBranch   Branch? @relation("FromBranch", fields: [fromBranchId], references: [id])

  // TO branch (required)
  toBranchId Int
  toBranch   Branch @relation("ToBranch", fields: [toBranchId], references: [id])

  temporary    Boolean   @default(false)
  expiresAt    DateTime?
  approvedBy   String
  transferDate DateTime  @default(now())

  createdAt DateTime @default(now())
}
