model AssetAssignmentHistory {
  id Int @id @default(autoincrement())

  assignmentId Int
  assignment   AssetAssignment @relation(fields: [assignmentId], references: [id])

  action AssignmentAction

  performedById Int?
  performedBy   Employee? @relation(fields: [performedById], references: [id])

  notes String?

  createdAt DateTime @default(now())
}

model AssetSpecification {
  id Int @id @default(autoincrement())

  assetId Int
  asset   Asset @relation(fields: [assetId], references: [id])

  key   String
  value String

  specificationGroup String? // GENERAL | ELECTRICAL | MECHANICAL | SOFTWARE | ACCESSORY | SUB_ASSET
  valueType          String? // TEXT | NUMBER | BOOLEAN | DATE | JSON
  unit               String?
  sortOrder          Int?     @default(0)
  isMandatory        Boolean? @default(false)
  source             String? // OEM | CLIENT | TECHNICIAN | IMPORT
  remarks            String?  @db.Text

